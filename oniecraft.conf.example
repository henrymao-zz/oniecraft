# ONIECraft Configuration
#
# Copy this file to oniecraft.conf and customize.
# All values override defaults from config.mk.
#
# Alternatively, set environment variables before running make:
#   ARCH=arm64 make image

# Target architecture: x86_64 or arm64
# ARCH = x86_64

# Network OS identity
# NOS_NAME = MyNOS
# NOS_VERSION = 1.0.0

# Ubuntu base
# UBUNTU_SUITE = noble
# UBUNTU_MIRROR = http://archive.ubuntu.com/ubuntu
# UBUNTU_COMPONENTS = main,universe

# Bootloader: grub (x86_64/UEFI) or uboot (ARM)
# BOOTLOADER = grub

# Install partition size in MB
# PART_SIZE_MB = 4096

# Custom kernel source directory (optional)
# Set to a linux source tree to compile a custom kernel.
# Leave empty to install the default Ubuntu kernel package.
# KERNEL_SRC = /path/to/linux-source

# Kernel .config file (optional, used with KERNEL_SRC)
# KERNEL_CONFIG = /path/to/.config

# Kernel version string (optional, auto-detected from source)
# KERNEL_VERSION = 6.1.0-custom

# Additional .deb packages to install (space-separated paths)
# INCLUDE_DEBS = packages/debs/my-package.deb packages/debs/other.deb

# Source packages to build and install (space-separated directories)
# Each directory should contain a Makefile, CMakeLists.txt, or install.sh
# INCLUDE_SOURCE_PKGS = packages/source/my-daemon packages/source/my-tool

# --- VM Testing ---

# Path to ONIE recovery ISO for KVM x86_64 (required for vm-create/vm-test)
# Build from https://github.com/opencomputeproject/onie with:
#   make -C build-config MACHINE=kvm_x86_64 recovery-iso
# ONIE_ISO = /path/to/onie-recovery-x86_64-kvm_x86_64-r0.iso

# VM memory in MB
# VM_MEM = 2048

# VM disk size in GB
# VM_DISK_SIZE = 40

# VM firmware: bios or uefi
# VM_FIRMWARE = bios

# KVM serial console port
# VM_KVM_PORT = 9000

# Host SSH port forwarded to VM
# VM_SSH_PORT = 3041
