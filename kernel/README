# Custom Kernel
#
# To use a custom kernel build, set KERNEL_SRC in oniecraft.conf:
#
#   KERNEL_SRC = /path/to/linux-source-tree
#   KERNEL_CONFIG = /path/to/.config  (optional)
#   KERNEL_VERSION = 6.1.0-custom    (optional, auto-detected)
#
# The kernel will be compiled using the appropriate cross-compiler
# for the target architecture. Required packages:
#
#   sudo apt install build-essential bc kmod cpio
#   sudo apt install gcc-aarch64-linux-gnu  (for arm64 cross-builds)
#
# If KERNEL_SRC is empty, the default Ubuntu kernel package
# (linux-image-generic) will be installed instead.
